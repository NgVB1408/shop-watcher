# Telegram bot token từ @BotFather
TELEGRAM_BOT_TOKEN=

# Chỉ những chat_id này được phép dùng bot (CSV). Để trống = ai cũng dùng được.
TELEGRAM_ALLOWED_CHAT_IDS=

# Khoảng poll (giây). Tối thiểu 30s.
POLL_INTERVAL_SECONDS=60

# Số sản phẩm mới nhất lấy mỗi lần
ITEMS_PER_CHECK=30

# SQLite path
DB_PATH=data/shop_watcher.db

# Log level
LOG_LEVEL=INFO

# HTTP proxy (optional)
HTTP_PROXY=

# Shopee cookies — JSON format (export từ Chrome extension "EditThisCookie", v.v.)
# Đây là cách work nhất. Bot dùng Playwright headless với cookies này.
SHOPEE_COOKIES_JSON=

# Fallback: format string `name=value; name=value;` (chỉ dùng nếu không có JSON)
SHOPEE_COOKIE=
