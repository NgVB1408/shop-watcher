# Telegram bot token từ @BotFather
TELEGRAM_BOT_TOKEN=

# Chỉ những chat_id này được phép dùng bot (phân cách bằng dấu phẩy). Để trống = ai cũng dùng được.
# Lấy chat_id bằng cách nhắn /start cho bot, log sẽ in ra.
TELEGRAM_ALLOWED_CHAT_IDS=

# Khoảng thời gian poll (giây). Default 300s = 5 phút. Tối thiểu 60s để tránh bị rate-limit.
POLL_INTERVAL_SECONDS=300

# Số sản phẩm mới nhất lấy mỗi lần check
ITEMS_PER_CHECK=30

# SQLite path
DB_PATH=data/shop_watcher.db

# Log level
LOG_LEVEL=INFO

# HTTP proxy (optional, ví dụ: http://127.0.0.1:1080)
# Bắt buộc dùng nếu IP residential VN của bạn bị Shopee block (error 90309999).
HTTP_PROXY=

# Shopee cookie string (paste nguyên đoạn từ DevTools > Application > Cookies).
# Nếu IP bị block, đây là cách work nhất: login Shopee bằng browser thường, copy cookies.
# Format: "SPC_F=xxx; SPC_EC=yyy; SPC_CLIENTID=zzz; ..."
# Bot tự refresh khi cookie hết hạn (log sẽ báo). Để trống nếu chạy trên VPS IP sạch.
SHOPEE_COOKIE=

# Khi bằng "1"/"true", bot sẽ tự lấy cookies bằng Playwright headless mỗi khi
# Shopee trả 403 (chỉ work nếu IP không bị captcha-block, vd VPS sạch).
SHOPEE_AUTO_COOKIE=0
